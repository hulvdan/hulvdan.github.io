{
  "emeraldwalk.runonsave": {
    "commands": [
      {
        "match": ".(json|css)$",
        "cmd": "prettier -w ${file}"
      },
      {
        "match": ".(md|css|html)$",
        "cmd": "uv run python build.py"
      },
      {
        "match": ".pyi?$",
        "cmd": "uv run ruff format ${file} && uv run ruff check --select I ${file} --fix"
      }
    ]
  },
  "liveServer.settings.multiRootWorkspaceName": "hulvdan.github.io"
}
